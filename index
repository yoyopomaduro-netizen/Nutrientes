<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NutriLent AI</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080808;
  --surface: #111;
  --surface2: #171717;
  --surface3: #1e1e1e;
  --accent: #b8f050;
  --accent-dim: rgba(184,240,80,0.08);
  --accent2: #50f0b8;
  --accent2-dim: rgba(80,240,184,0.08);
  --text: #f2f2f2;
  --muted: #444;
  --muted2: #777;
  --error: #ff5f5f;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.1);
  --radius: 18px;
  --radius-sm: 10px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Mono', monospace;
  min-height: 100vh;
  overflow-x: hidden;
}

.tabs {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(8,8,8,0.95);
  backdrop-filter: blur(20px);
  border-top: 1px solid var(--border);
  display: flex; z-index: 50;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-btn {
  flex: 1; padding: 14px 8px 12px;
  background: none; border: none;
  color: var(--muted2); cursor: pointer;
  display: flex; flex-direction: column;
  align-items: center; gap: 4px;
  transition: color 0.2s;
  font-family: 'DM Mono', monospace;
}
.tab-btn.active { color: var(--accent); }
.tab-btn .tab-icon { font-size: 18px; }
.tab-btn .tab-label { font-size: 8px; letter-spacing: 1.5px; text-transform: uppercase; }

.page { display: none; padding: 40px 20px 100px; max-width: 480px; margin: 0 auto; }
.page.active { display: block; animation: fadeUp 0.3s ease both; }

.header { text-align: center; margin-bottom: 32px; }
.header .eyebrow {
  font-size: 9px; letter-spacing: 5px;
  color: var(--accent); text-transform: uppercase;
  margin-bottom: 10px; opacity: 0.6;
}
.header h1 {
  font-family: 'Syne', sans-serif;
  font-size: 44px; font-weight: 800;
  letter-spacing: -3px; line-height: 1;
}
.header h1 .green { color: var(--accent); }
.header .sub { color: var(--muted2); font-size: 10px; margin-top: 8px; letter-spacing: 2px; }

.auth-row {
  display: flex; align-items: center; justify-content: center;
  margin-top: 14px; gap: 10px;
}

.btn-login {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 9px 18px;
  background: var(--surface);
  border: 1px solid rgba(184,240,80,0.25);
  border-radius: 40px;
  color: var(--text);
  font-family: 'DM Mono', monospace;
  font-size: 10px; letter-spacing: 1.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s;
}
.btn-login:hover { border-color: rgba(184,240,80,0.6); background: var(--surface2); color: var(--accent); }
.btn-login .g-icon { font-size: 14px; }

.user-pill {
  display: none; align-items: center; gap: 8px;
  background: var(--surface);
  border: 1px solid rgba(184,240,80,0.15);
  border-radius: 40px;
  padding: 6px 14px 6px 6px;
  cursor: default;
}
.user-pill.show { display: inline-flex; }
.user-avatar {
  width: 26px; height: 26px; border-radius: 50%;
  object-fit: cover; border: 1.5px solid rgba(184,240,80,0.4);
  flex-shrink: 0;
}
.user-name { font-size: 10px; font-weight: 600; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.btn-logout {
  font-size: 9px; color: var(--muted2); background: none;
  border: none; cursor: pointer; letter-spacing: 1px;
  font-family: 'DM Mono', monospace;
  transition: color 0.2s; padding: 0; margin-left: 2px;
}
.btn-logout:hover { color: var(--error); }

.sync-bar {
  display: none; align-items: center; gap: 8px;
  font-size: 9px; color: var(--accent2); letter-spacing: 1.5px;
  text-transform: uppercase; margin-bottom: 12px;
  padding: 8px 12px; background: var(--accent2-dim);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(80,240,184,0.12);
}
.sync-bar.show { display: flex; }
.sync-dot { width: 6px; height: 6px; background: var(--accent2); border-radius: 50%; animation: pulse 1.5s infinite; }

.section-label {
  font-size: 9px; letter-spacing: 4px;
  text-transform: uppercase; color: var(--muted2);
}

.metas-bar {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 10px; margin-bottom: 24px;
}
.meta-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm); padding: 14px 16px;
}
.meta-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.meta-icon { font-size: 14px; }
.meta-pct { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700; }
.meta-pct.green { color: var(--accent); }
.meta-pct.teal { color: var(--accent2); }
.meta-pct.warn { color: #f0a050; }
.meta-label { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted2); margin-bottom: 4px; }
.meta-vals { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; line-height: 1; }
.meta-vals em { font-size: 9px; font-style: normal; font-family: 'DM Mono', monospace; color: var(--muted2); }
.meta-bar { margin-top: 10px; height: 3px; background: var(--surface3); border-radius: 2px; overflow: hidden; }
.meta-bar-fill { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
.meta-bar-fill.green { background: var(--accent); }
.meta-bar-fill.teal { background: var(--accent2); }
.meta-bar-fill.warn { background: #f0a050; }

.upload-zone {
  border: 1.5px dashed rgba(255,255,255,0.08);
  border-radius: var(--radius); padding: 36px 20px;
  text-align: center; cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  position: relative; overflow: hidden;
  background: var(--surface); margin-bottom: 0;
}
.upload-zone:hover { border-color: rgba(184,240,80,0.3); background: var(--surface2); }
.upload-zone.has-image { padding: 0; border-color: rgba(184,240,80,0.25); }
.upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.upload-icon { font-size: 32px; margin-bottom: 10px; display: block; }
.upload-label { font-size: 11px; color: var(--muted2); letter-spacing: 0.5px; }
.upload-label strong { color: var(--accent); }
#preview { width: 100%; border-radius: var(--radius); display: none; max-height: 280px; object-fit: cover; }

.camera-section { margin-top: 14px; }
.camera-toggle {
  width: 100%; padding: 14px;
  background: none; color: var(--muted2);
  font-family: 'DM Mono', monospace; font-size: 10px;
  letter-spacing: 2px; text-transform: uppercase;
  border: 1px solid var(--border2);
  border-radius: var(--radius-sm); cursor: pointer;
  transition: all 0.2s; display: flex;
  align-items: center; justify-content: center; gap: 8px;
}
.camera-toggle:hover { border-color: rgba(184,240,80,0.3); color: var(--accent); }
.camera-wrap {
  display: none; position: relative;
  border-radius: var(--radius); overflow: hidden;
  background: #000; margin-top: 10px;
}
.camera-wrap.open { display: block; }
#cameraFeed { width: 100%; max-height: 280px; object-fit: cover; display: block; }
.camera-capture {
  position: absolute; bottom: 14px; left: 50%;
  transform: translateX(-50%);
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--accent); border: 3px solid #000;
  cursor: pointer; transition: transform 0.1s;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
}
.camera-capture:active { transform: translateX(-50%) scale(0.92); }
.camera-close {
  position: absolute; top: 10px; right: 10px;
  background: rgba(0,0,0,0.6); border: none;
  color: var(--text); width: 30px; height: 30px;
  border-radius: 50%; cursor: pointer; font-size: 14px;
}

.btn-analyze {
  width: 100%; margin-top: 12px; padding: 18px;
  background: var(--accent); color: #000;
  font-family: 'Syne', sans-serif; font-size: 12px;
  font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
  border: none; border-radius: var(--radius); cursor: pointer;
  transition: opacity 0.2s, transform 0.1s;
}
.btn-analyze:hover { opacity: 0.85; }
.btn-analyze:active { transform: scale(0.98); }
.btn-analyze:disabled { opacity: 0.3; cursor: not-allowed; }

.scan-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(8,8,8,0.96); z-index: 200;
  flex-direction: column; align-items: center;
  justify-content: center; gap: 28px;
}
.scan-overlay.open { display: flex; animation: fadeIn 0.3s ease both; }
.scan-ring {
  width: 100px; height: 100px;
  border: 2px solid var(--border2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
.scan-inner {
  position: absolute; width: 70px; height: 70px;
  border: 1.5px solid var(--border);
  border-bottom-color: var(--accent2);
  border-radius: 50%;
  animation: spin 1.5s linear infinite reverse;
}
.scan-dot {
  position: absolute; width: 10px; height: 10px;
  background: var(--accent); border-radius: 50%;
}
.scan-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
.scan-label {
  font-family: 'Syne', sans-serif; font-size: 18px;
  font-weight: 700; letter-spacing: -0.5px;
}
.scan-sub {
  font-size: 10px; letter-spacing: 3px;
  color: var(--muted2); text-transform: uppercase;
  animation: pulse 1.5s ease infinite;
}
.scan-steps {
  display: flex; flex-direction: column; gap: 10px;
  width: 220px;
}
.scan-step {
  display: flex; align-items: center; gap: 12px;
  font-size: 11px; color: var(--muted2);
  transition: color 0.4s;
}
.scan-step.done { color: var(--accent); }
.scan-step .step-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--muted); flex-shrink: 0;
  transition: background 0.4s;
}
.scan-step.done .step-dot { background: var(--accent); }

.error-box {
  background: rgba(255,95,95,0.06);
  border: 1px solid rgba(255,95,95,0.18);
  border-radius: var(--radius-sm);
  padding: 12px 16px; color: var(--error);
  font-size: 11px; margin-top: 12px;
  display: none; line-height: 1.6;
}

.result-card {
  margin-top: 18px; background: var(--surface);
  border: 1px solid var(--border); border-radius: var(--radius);
  overflow: hidden; display: none;
  animation: fadeUp 0.35s ease both;
}
.result-header {
  padding: 20px 22px 16px; border-bottom: 1px solid var(--border);
  display: flex; justify-content: space-between;
  align-items: flex-start; gap: 14px;
}
.result-dish {
  font-family: 'Syne', sans-serif; font-size: 18px;
  font-weight: 700; letter-spacing: -0.5px; line-height: 1.2;
}
.result-cal {
  background: var(--accent-dim);
  border: 1px solid rgba(184,240,80,0.15);
  border-radius: var(--radius-sm); padding: 10px 14px;
  text-align: center; flex-shrink: 0;
}
.cal-num {
  font-family: 'Syne', sans-serif; font-size: 22px;
  font-weight: 800; color: var(--accent); display: block; line-height: 1;
}
.cal-label { font-size: 8px; letter-spacing: 2px; color: var(--muted2); text-transform: uppercase; }
.macros { display: grid; grid-template-columns: 1fr 1fr 1fr; border-bottom: 1px solid var(--border); }
.macro-item { padding: 14px 10px; text-align: center; border-right: 1px solid var(--border); }
.macro-item:last-child { border-right: none; }
.macro-icon { font-size: 13px; margin-bottom: 5px; }
.macro-val { font-family: 'Syne', sans-serif; font-size: 19px; font-weight: 700; display: block; }
.macro-val em { font-size: 9px; font-style: normal; font-family: 'DM Mono', monospace; color: var(--muted2); }
.macro-name { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-top: 2px; }
.ingredients { padding: 12px 20px; border-bottom: 1px solid var(--border); }
.ing-label { font-size: 8px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
.ing-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.tag { background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; font-size: 10px; color: var(--muted2); }
.consejo { margin: 12px 20px 18px; padding: 12px 14px; font-size: 11px; color: var(--muted2); line-height: 1.9; border-left: 2px solid var(--accent); background: var(--accent-dim); border-radius: 0 8px 8px 0; }

.ai-summary-btn {
  width: 100%; margin-top: 12px; padding: 15px;
  background: none; color: var(--accent2);
  font-family: 'DM Mono', monospace; font-size: 10px;
  letter-spacing: 2px; text-transform: uppercase;
  border: 1px solid rgba(80,240,184,0.2);
  border-radius: var(--radius-sm); cursor: pointer;
  transition: all 0.2s; display: flex;
  align-items: center; justify-content: center; gap: 8px;
}
.ai-summary-btn:hover { background: var(--accent2-dim); border-color: rgba(80,240,184,0.4); }
.ai-summary-card {
  background: var(--surface); border: 1px solid rgba(80,240,184,0.15);
  border-radius: var(--radius); padding: 20px 22px;
  margin-top: 12px; display: none;
  animation: fadeUp 0.3s ease both;
}
.ai-summary-card .ai-label {
  font-size: 8px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent2);
  margin-bottom: 12px; opacity: 0.7;
}
.ai-summary-text {
  font-size: 12px; color: var(--muted2);
  line-height: 1.9; white-space: pre-wrap;
}
.ai-typing::after {
  content: '▋'; animation: blink 0.8s infinite;
  color: var(--accent2);
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.chart-wrap {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 18px 18px 14px;
  margin-bottom: 16px;
}
.chart-title { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted2); margin-bottom: 14px; }
.chart-bars { display: flex; align-items: flex-end; gap: 6px; height: 70px; }
.chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.chart-bar { width: 100%; border-radius: 4px 4px 0 0; background: var(--accent); transition: height 0.5s ease; opacity: 0.6; min-height: 3px; }
.chart-bar.today { opacity: 1; }
.chart-day { font-size: 8px; color: var(--muted2); }
.chart-kcal { font-size: 7px; color: var(--muted2); }
.history-list { display: flex; flex-direction: column; gap: 8px; }
.history-item {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; padding: 12px 14px;
  display: grid; grid-template-columns: 44px 1fr auto;
  gap: 12px; align-items: center; cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}
.history-item:hover { border-color: rgba(184,240,80,0.25); background: var(--surface2); }
.history-thumb { width: 44px; height: 44px; border-radius: 8px; object-fit: cover; background: var(--surface3); }
.history-dish { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 600; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.history-meta { font-size: 9px; color: var(--muted2); }
.history-kcal { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: var(--accent); text-align: right; }
.history-kcal span { display: block; font-size: 8px; font-family: 'DM Mono', monospace; font-weight: 400; color: var(--muted); }
.history-empty { text-align: center; color: var(--muted); font-size: 11px; padding: 32px; border: 1px dashed var(--border); border-radius: var(--radius); letter-spacing: 1px; }
.hist-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.btn-clear { font-size: 9px; color: var(--error); cursor: pointer; opacity: 0.45; transition: opacity 0.2s; background: none; border: none; font-family: 'DM Mono', monospace; letter-spacing: 2px; }
.btn-clear:hover { opacity: 1; }

.profile-avatar {
  width: 72px; height: 72px; border-radius: 50%;
  background: var(--accent-dim); border: 2px solid rgba(184,240,80,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; margin: 0 auto 20px; overflow: hidden;
}
.profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
.profile-name { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; text-align: center; margin-bottom: 4px; }
.profile-goal { font-size: 10px; color: var(--accent); letter-spacing: 2px; text-align: center; text-transform: uppercase; margin-bottom: 28px; }
.profile-form { display: flex; flex-direction: column; gap: 14px; }
.field-label { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted2); margin-bottom: 6px; display: block; }
.field-input {
  width: 100%; background: var(--surface);
  border: 1px solid var(--border2); border-radius: var(--radius-sm);
  padding: 13px 14px; color: var(--text);
  font-family: 'DM Mono', monospace; font-size: 14px;
  outline: none; transition: border-color 0.2s;
}
.field-input:focus { border-color: rgba(184,240,80,0.4); }
.field-select {
  width: 100%; background: var(--surface);
  border: 1px solid var(--border2); border-radius: var(--radius-sm);
  padding: 13px 14px; color: var(--text);
  font-family: 'DM Mono', monospace; font-size: 13px;
  outline: none; cursor: pointer; appearance: none;
}
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.btn-save-profile {
  width: 100%; margin-top: 8px; padding: 16px;
  background: var(--accent); color: #000;
  font-family: 'Syne', sans-serif; font-size: 12px;
  font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
  border: none; border-radius: var(--radius-sm); cursor: pointer;
  transition: opacity 0.2s;
}
.btn-save-profile:hover { opacity: 0.85; }
.metas-calc {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius-sm); padding: 16px;
  margin-top: 4px; display: none;
}
.metas-calc-title { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted2); margin-bottom: 12px; }
.metas-calc-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-size: 11px; color: var(--muted2); }
.metas-calc-val { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--accent); }
.cloud-badge {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 8px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--accent2); padding: 4px 10px;
  background: var(--accent2-dim);
  border: 1px solid rgba(80,240,184,0.15);
  border-radius: 20px; margin-top: 10px;
}

@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
</style>
</head>
<body>

<div class="scan-overlay" id="scanOverlay">
  <div class="scan-wrap">
    <div class="scan-ring"></div>
    <div class="scan-inner"></div>
    <div class="scan-dot"></div>
  </div>
  <div>
    <div class="scan-label">Analizando</div>
    <div class="scan-sub" id="scanSub">preparando análisis</div>
  </div>
  <div class="scan-steps">
    <div class="scan-step" id="step1"><div class="step-dot"></div>Detectando ingredientes</div>
    <div class="scan-step" id="step2"><div class="step-dot"></div>Calculando macronutrientes</div>
    <div class="scan-step" id="step3"><div class="step-dot"></div>Generando consejo nutricional</div>
  </div>
</div>

<div class="page active" id="page-scan">
  <div class="header">
    <div class="eyebrow">AI vision · análisis nutricional</div>
    <h1>Nutri<span class="green">Lent</span></h1>
    <div class="sub" id="greetUser">Fotografía · Analiza · Aprende</div>

    <div class="auth-row">
      <button class="btn-login" id="btnLogin">
        <span class="g-icon">🔐</span>
        Iniciar sesión con Google
      </button>
      <div class="user-pill" id="userPill">
        <img class="user-avatar" id="userAvatar" src="" alt="">
        <span class="user-name" id="userDisplayName">—</span>
        <button class="btn-logout" id="btnLogout">· salir</button>
      </div>
    </div>
  </div>

  <div class="sync-bar" id="syncBar">
    <div class="sync-dot"></div>
    <span id="syncMsg">Sincronizando con la nube...</span>
  </div>

  <div class="metas-bar">
    <div class="meta-card">
      <div class="meta-top">
        <span class="meta-icon">🔥</span>
        <span class="meta-pct green" id="pctCal">0%</span>
      </div>
      <div class="meta-label">Calorías hoy</div>
      <div class="meta-vals"><span id="totalCal">0</span><em> / <span id="goalCalShow">2000</span> kcal</em></div>
      <div class="meta-bar"><div class="meta-bar-fill green" id="barCal" style="width:0%"></div></div>
    </div>
    <div class="meta-card">
      <div class="meta-top">
        <span class="meta-icon">💪</span>
        <span class="meta-pct teal" id="pctProt">0%</span>
      </div>
