<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import {
  getAuth, GoogleAuthProvider, signInWithPopup, signInWithRedirect,
  getRedirectResult, signOut, onAuthStateChanged
} from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
import {
  getFirestore, doc, getDoc, setDoc, collection, query, orderBy, limit, getDocs, writeBatch
} from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

// ⚠️ IMPORTANTE: Reemplaza estas credenciales con las tuyas desde Firebase Console
const firebaseConfig = {
  apiKey: "YOUR_API_KEY_HERE",
  authDomain: "YOUR_AUTH_DOMAIN",
  projectId: "YOUR_PROJECT_ID",
  storageBucket: "YOUR_STORAGE_BUCKET",
  messagingSenderId: "YOUR_MESSAGING_SENDER_ID",
  appId: "YOUR_APP_ID"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const provider = new GoogleAuthProvider();

const WORKER_URL = "https://nutrientes.yoyopomaduro.workers.dev/api/chat";
let currentUser = null, historyData = [], metas = { cal: 2000, prot: 150 }, profile = {};
let imageBase64 = null, cameraStream = null, saveProfileTimeout = null, scanTimer = null;
let isAnalyzing = false;

// ════════════════════════════════════════ HELPERS ════════════════════════════════════════
function lsGet(k, def) { 
  try { return JSON.parse(localStorage.getItem(k) || 'null') ?? def; } catch(e) { return def; } 
}
function lsSet(k, v) { 
  try { localStorage.setItem(k, JSON.stringify(v)); } catch(e) {} 
}

function getTodayKey() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

function generateUniqueId() {
  return `${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
}

function validateProfile(peso, altura, edad) {
  if (peso < 20 || peso > 300) throw new Error('Peso debe estar entre 20-300 kg');
  if (altura < 100 || altura > 250) throw new Error('Altura debe estar entre 100-250 cm');
  if (edad < 13 || edad > 120) throw new Error('Edad debe estar entre 13-120 años');
  return true;
}

function validateAnalysisResult(r) {
  if (!r.plato || typeof r.plato !== 'string' || !r.plato.trim()) throw new Error('Plato inválido');
  if (!Number.isInteger(r.calorias) || r.calorias < 0 || r.calorias > 5000) throw new Error('Calorías no válidas (0-5000)');
  if (!Number.isInteger(r.proteinas) || r.proteinas < 0 || r.proteinas > 500) throw new Error('Proteínas no válidas (0-500g)');
  if (!Number.isInteger(r.carbos) || r.carbos < 0 || r.carbos > 500) throw new Error('Carbos no válidos (0-500g)');
  if (!Number.isInteger(r.grasas) || r.grasas < 0 || r.grasas > 500) throw new Error('Grasas no válidas (0-500g)');
  if (!Array.isArray(r.ingredientes)) r.ingredientes = [];
  r.ingredientes = r.ingredientes.filter(ing => typeof ing === 'string' && ing.trim());
  if (typeof r.consejo !== 'string') r.consejo = '';
  return r;
}

function checkAndResetDaily() {
  const lastDate = localStorage.getItem('nutrilent_lastDate');
  const today = getTodayKey();
  if (lastDate !== today) {
    localStorage.setItem('nutrilent_lastDate', today);
    console.log('✅ Nuevo día detectado, metas reiniciadas');
  }
}

function showSync(msg) {
  document.getElementById('syncMsg').textContent = msg || 'Sincronizando...';
  document.getElementById('syncBar').classList.add('show');
}

function hideSync() {
  document.getElementById('syncBar').classList.remove('show');
}

function showError(msg) {
  const box = document.getElementById('errorBox');
  box.textContent = msg;
  box.style.display = 'block';
  setTimeout(() => { box.style.display = 'none'; }, 5000);
}

// ════════════════════════════════════════ INIT ════════════════════════════════════════
historyData = lsGet('nutrilent_history', []);
metas = lsGet('nutrilent_metas', { cal: 2000, prot: 150 });
profile = lsGet('nutrilent_profile', {});
checkAndResetDaily();
updateMetasUI();
renderHistory();
loadProfileUI();

// ════════════════════════════════════════ AUTH ════════════════════════════════════════
getRedirectResult(auth).then(r => {
  if (r?.user) console.log('✅ Login exitoso:', r.user.displayName);
}).catch(e => {
  if (e.code !== 'auth/no-auth-event') console.warn('⚠️ Redirect error:', e.message);
});

document.getElementById('btnLogin').addEventListener('click', async () => {
  try {
    await signInWithPopup(auth, provider);
  } catch(e) {
    if (['auth/popup-blocked', 'auth/popup-closed-by-user', 'auth/cancelled-popup-request'].includes(e.code)) {
      try { await signInWithRedirect(auth, provider); } 
      catch(e2) { showError('Error de login: ' + e2.message); }
    } else {
      showError('Error: ' + e.message);
    }
  }
});

document.getElementById('btnLogout').addEventListener('click', async () => {
  await signOut(auth);
});

onAuthStateChanged(auth, async (user) => {
  currentUser = user;
  if (user) {
    document.getElementById('btnLogin').style.display = 'none';
    document.getElementById('userPill').classList.add('show');
    document.getElementById('userAvatar').src = user.photoURL || '';
    document.getElementById('userDisplayName').textContent = user.displayName?.split(' ')[0] || 'Usuario';
    document.getElementById('greetUser').textContent = '¡Hola, ' + (user.displayName?.split(' ')[0] || 'tú') + '! 👋';
    document.getElementById('cloudBadge').style.display = 'inline-flex';

    const avatarWrap = document.getElementById('profileAvatarWrap');
    avatarWrap.innerHTML = '';
    if (user.photoURL) {
      const img = document.createElement('img');
      img.src = user.photoURL;
      img.alt = 'avatar';
      img.onerror = () => { avatarWrap.textContent = '🧑'; };
      avatarWrap.appendChild(img);
    } else {
      avatarWrap.textContent = '🧑';
    }

    await loadFromFirestore(user.uid);
  } else {
    document.getElementById('btnLogin').style.display = '';
    document.getElementById('userPill').classList.remove('show');
    document.getElementById('greetUser').textContent = 'Fotografía · Analiza · Aprende';
    document.getElementById('cloudBadge').style.display = 'none';
    document.getElementById('profileAvatarWrap').textContent = '🧑';
  }
});

// ════════════════════════════════════════ FIRESTORE ════════════════════════════════════════
async function loadFromFirestore(uid) {
  showSync('Cargando datos...');
  try {
    const profileDoc = await getDoc(doc(db, 'users', uid));
    if (profileDoc.exists()) {
      const d = profileDoc.data();
      if (d.profile) { profile = d.profile; lsSet('nutrilent_profile', profile); }
      if (d.metas) { metas = d.metas; lsSet('nutrilent_metas', metas); }
      loadProfileUI();
      updateMetasUI();
    }

    const snap = await getDocs(query(collection(db, 'users', uid, 'history'), orderBy('id', 'desc'), limit(30)));
    if (!snap.empty) {
      historyData = snap.docs.map(d => d.data());
      lsSet('nutrilent_history', historyData);
      updateMetasUI();
      renderHistory();
    }
  } catch(e) {
    console.warn('⚠️ Firestore error:', e);
  }
  hideSync();
}

async function saveProfileToFirestore() {
  if (!currentUser) return;
  try {
    await setDoc(doc(db, 'users', currentUser.uid), { profile, metas }, { merge: true });
  } catch(e) { console.warn('⚠️ Save error:', e); }
}

async function saveEntryToFirestore(entry) {
  if (!currentUser) return;
  try {
    await setDoc(doc(db, 'users', currentUser.uid, 'history', String(entry.id)), entry);
  } catch(e) { console.warn('⚠️ Entry save error:', e); }
}

async function clearFirestoreHistory() {
  if (!currentUser) return;
  showSync('Borrando historial...');
  try {
    const snap = await getDocs(query(collection(db, 'users', currentUser.uid, 'history')));
    const batch = writeBatch(db);
    snap.docs.forEach(d => batch.delete(d.ref));
    await batch.commit();
  } catch(e) { console.warn('⚠️ Clear error:', e); }
  hideSync();
}

// ════════════════════════════════════════ TABS ════════════════════════════════════════
window.goTab = function(name, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'history') renderHistory();
};

// ════════════════════════════════════════ PERFIL ════════════════════════════════════════
function loadProfileUI() {
  if (!profile.nombre) return;
  document.getElementById('profileNameDisplay').textContent = profile.nombre;
  document.getElementById('profileGoalDisplay').textContent = goalLabel(profile.objetivo);
  document.getElementById('pNombre').value = profile.nombre || '';
  document.getElementById('pPeso').value = profile.peso || '';
  document.getElementById('pAltura').value = profile.altura || '';
  document.getElementById('pEdad').value = profile.edad || '';
  if (profile.sexo) document.getElementById('pSexo').value = profile.sexo;
  if (profile.objetivo) document.getElementById('pObjetivo').value = profile.objetivo;
  if (profile.actividad) document.getElementById('pActividad').value = profile.actividad;
}

function goalLabel(o) {
  return o === 'bajar' ? 'Objetivo: bajar de peso' : o === 'musculo' ? 'Objetivo: ganar músculo' : 'Objetivo: mantenerse';
}

window.saveProfile = async function() {
  try {
    const nombre = document.getElementById('pNombre').value.trim();
    const peso = parseFloat(document.getElementById('pPeso').value) || 70;
    const altura = parseFloat(document.getElementById('pAltura').value) || 170;
    const edad = parseInt(document.getElementById('pEdad').value) || 25;
    const sexo = document.getElementById('pSexo').value;
    const objetivo = document.getElementById('pObjetivo').value;
    const actividad = parseFloat(document.getElementById('pActividad').value);

    validateProfile(peso, altura, edad);
    if (!nombre) throw new Error('Nombre requerido');

    profile = { nombre, peso, altura, edad, sexo, objetivo, actividad };
    lsSet('nutrilent_profile', profile);

    let tmb = sexo === 'm'
      ? (10*peso) + (6.25*altura) - (5*edad) + 5
      : (10*peso) + (6.25*altura) - (5*edad) - 161;
    let tdee = Math.round(tmb * actividad);
    let calMeta = objetivo === 'bajar' ? Math.round(tdee * 0.82) : objetivo === 'musculo' ? Math.round(tdee * 1.1) : tdee;
    let protMeta = objetivo === 'musculo' ? Math.round(peso * 2.2) : objetivo === 'bajar' ? Math.round(peso * 1.8) : Math.round(peso * 1.4);

    metas = { cal: calMeta, prot: protMeta };
    lsSet('nutrilent_metas', metas);

    document.getElementById('calcCalVal').textContent = calMeta + ' kcal';
    document.getElementById('calcProtVal').textContent = protMeta + 'g';
    document.getElementById('metasCalcCard').style.display = 'block';
    document.getElementById('profileNameDisplay').textContent = nombre;
    document.getElementById('profileGoalDisplay').textContent = goalLabel(objetivo);
    document.getElementById('greetUser').textContent = '¡Hola, ' + nombre + '! 👋';
    updateMetasUI();

    if (currentUser) {
      clearTimeout(saveProfileTimeout);
      saveProfileTimeout = setTimeout(async () => {
        showSync('Guardando perfil...');
        await saveProfileToFirestore();
        hideSync();
      }, 1000);
    }
  } catch(err) {
    showError('Error: ' + err.message);
  }
};

// ════════════════════════════════════════ METAS UI ════════════════════════════════════════
function updateMetasUI() {
  const todayKey = getTodayKey();
  const todayEntries = historyData.filter(e => {
    const d = new Date(e.id);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    return key === todayKey;
  });

  const tCal = todayEntries.reduce((s, e) => s + (Number.isInteger(e.calorias) ? e.calorias : 0), 0);
  const tProt = todayEntries.reduce((s, e) => s + (Number.isInteger(e.proteinas) ? e.proteinas : 0), 0);
  const pCal = Math.min(Math.round((tCal / metas.cal) * 100), 100);
  const pProt = Math.min(Math.round((tProt / metas.prot) * 100), 100);

  document.getElementById('goalCalShow').textContent = metas.cal;
  document.getElementById('goalProtShow').textContent = metas.prot;
  document.getElementById('totalCal').textContent = tCal;
  document.getElementById('totalProt').textContent = tProt;
  document.getElementById('pctCal').textContent = pCal + '%';
  document.getElementById('pctProt').textContent = pProt + '%';
  document.getElementById('barCal').style.width = pCal + '%';
  document.getElementById('barProt').style.width = pProt + '%';

  const cc = pCal >= 100 ? 'warn' : 'green';
  const cp = pProt >= 100 ? 'warn' : 'teal';
  document.getElementById('pctCal').className = 'meta-pct ' + cc;
  document.getElementById('barCal').className = 'meta-bar-fill ' + cc;
  document.getElementById('pctProt').className = 'meta-pct ' + cp;
  document.getElementById('barProt').className = 'meta-bar-fill ' + cp;
}

// ════════════════════════════════════════ CÁMARA ════════════════════════════════════════
window.toggleCamera = async function() {
  const wrap = document.getElementById('cameraWrap');
  if (wrap.classList.contains('open')) { closeCamera(); return; }
  try {
    cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    document.getElementById('cameraFeed').srcObject = cameraStream;
    wrap.classList.add('open');
  } catch(e) {
    closeCamera();
    showError('No se pudo acceder a cámara: ' + e.message);
  }
};

window.capturePhoto = function() {
  try {
    const video = document.getElementById('cameraFeed');
    const canvas = document.createElement('canvas');
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);
    imageBase64 = canvas.toDataURL('image/jpeg', 0.92);
    const img = document.getElementById('preview');
    img.src = imageBase64;
    img.style.display = 'block';
    document.getElementById('uploadIcon').style.display = 'none';
    document.getElementById('uploadLabel').style.display = 'none';
    document.getElementById('uploadZone').classList.add('has-image');
    closeCamera();
  } catch(e) {
    showError('Error al capturar: ' + e.message);
  }
};

window.closeCamera = function() {
  if (cameraStream) {
    cameraStream.getTracks().forEach(t => t.stop());
    cameraStream = null;
  }
  document.getElementById('cameraWrap').classList.remove('open');
  document.getElementById('cameraFeed').srcObject = null;
};

// ════════════════════════════════════════ FILE INPUT ════════════════════════════════════════
document.getElementById('file').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  if (file.size > 5 * 1024 * 1024) {
    showError('Imagen muy grande (máx 5MB)');
    return;
  }
  const reader = new FileReader();
  reader.onload = ev => {
    imageBase64 = ev.target.result;
    const img = document.getElementById('preview');
    img.src = imageBase64;
    img.style.display = 'block';
    document.getElementById('uploadIcon').style.display = 'none';
    document.getElementById('uploadLabel').style.display = 'none';
    document.getElementById('uploadZone').classList.add('has-image');
  };
  reader.onerror = () => {
    showError('Error al leer la imagen');
  };
  reader.readAsDataURL(file);
});

// ════════════════════════════════════════ SCAN ANIMATION ════════════════════════════════════════
function startScanAnimation() {
  document.getElementById('scanOverlay').classList.add('open');
  const steps = ['step1', 'step2', 'step3'];
  const subs = ['detectando ingredientes...', 'calculando macronutrientes...', 'generando consejo...'];
  let i = 0;
  scanTimer = setInterval(() => {
    if (i < steps.length) {
      document.getElementById(steps[i]).classList.add('done');
      document.getElementById('scanSub').textContent = subs[i];
      i++;
    }
  }, 900);
}

function stopScanAnimation() {
  clearInterval(scanTimer);
  document.getElementById('scanOverlay').classList.remove('open');
  ['step1', 'step2', 'step3'].forEach(s => document.getElementById(s).classList.remove('done'));
  document.getElementById('scanSub').textContent = 'preparando análisis';
}

function stopScanAnimation() {
  clearInterval(scanTimer);
  document.getElementById('scanOverlay').classList.remove('open');
  ['step1', 'step2', 'step3'].forEach(s => document.getElementById(s).classList.remove('done'));
  document.getElementById('scanSub').textContent = 'preparando análisis';
}

// ═══════════════════════���════════════════ ANALYZE ════════════════════════════════════════
window.analyze = async function() {
  if (isAnalyzing) return;
  
  const errorBox = document.getElementById('errorBox');
  const btn = document.getElementById('btnAnalyze');
  errorBox.style.display = 'none';
  document.getElementById('resultCard').style.display = 'none';
  document.getElementById('aiSummaryBtn').style.display = 'none';

  if (!imageBase64) {
    showError('Por favor sube una foto primero');
    return;
  }

  isAnalyzing = true;
  btn.disabled = true;
  startScanAnimation();

  try {
    const base64Data = imageBase64.split(',')[1];
    const response = await fetch(WORKER_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ image: base64Data })
    });

    if (!response.ok) throw new Error('Error en análisis: ' + response.statusText);
    
    const data = await response.json();
    const result = validateAnalysisResult(data);

    document.getElementById('dishName').textContent = result.plato;
    document.getElementById('calNum').textContent = result.calorias;
    document.getElementById('protVal').textContent = result.proteinas;
    document.getElementById('carbVal').textContent = result.carbos;
    document.getElementById('fatVal').textContent = result.grasas;
    document.getElementById('consejo').textContent = result.consejo;

    const ingTags = document.getElementById('ingTags');
    ingTags.innerHTML = result.ingredientes.map(ing => 
      `<span class="tag">${escapeHTML(ing)}</span>`
    ).join('');

    stopScanAnimation();
    document.getElementById('resultCard').style.display = 'block';
    document.getElementById('aiSummaryBtn').style.display = 'flex';

    const entry = {
      id: generateUniqueId(),
      plato: result.plato,
      calorias: result.calorias,
      proteinas: result.proteinas,
      carbos: result.carbos,
      grasas: result.grasas,
      ingredientes: result.ingredientes,
      consejo: result.consejo,
      timestamp: new Date().toISOString()
    };

    historyData.unshift(entry);
    lsSet('nutrilent_history', historyData);
    await saveEntryToFirestore(entry);
    updateMetasUI();
    renderHistory();

  } catch(err) {
    stopScanAnimation();
    showError('Error: ' + err.message);
  } finally {
    isAnalyzing = false;
    btn.disabled = false;
  }
};

function escapeHTML(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// ════════════════════════════════════════ AI SUMMARY ════════════════════════════════════════
window.getAISummary = async function() {
  const btn = document.getElementById('aiSummaryBtn');
  const card = document.getElementById('aiSummaryCard');
  const text = document.getElementById('aiSummaryText');

  btn.disabled = true;
  card.style.display = 'block';
  text.textContent = '';
  text.classList.add('ai-typing');

  try {
    const todayKey = getTodayKey();
    const todayEntries = historyData.filter(e => {
      const d = new Date(e.id);
      const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
      return key === todayKey;
    });

    const summary = todayEntries.map(e => `${e.plato} (${e.calorias} kcal, ${e.proteinas}g prot)`).join(', ');
    const prompt = `El usuario ha comido hoy: ${summary}. Dar una recomendación nutricional breve en español.`;

    const response = await fetch(WORKER_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt: prompt })
    });

    if (!response.ok) throw new Error('Error en IA');
    
    const data = await response.json();
    text.classList.remove('ai-typing');
    text.textContent = data.recommendation || 'Recomendación no disponible';

  } catch(err) {
    text.classList.remove('ai-typing');
    text.textContent = 'Error al generar recomendación: ' + err.message;
  } finally {
    btn.disabled = false;
  }
};

// ════════════════════════════════════════ HISTORY ════════════════════════════════════════
function renderHistory() {
  const list = document.getElementById('historyList');
  const chart = document.getElementById('chartWrap');
  
  if (historyData.length === 0) {
    list.innerHTML = '<div class="history-empty">📭 Sin historial aún</div>';
    chart.style.display = 'none';
    return;
  }

  // Gráfico de últimos 7 días
  const last7 = getLast7DaysData();
  const maxCal = Math.max(...last7.map(d => d.calorias), 1);
  
  let barsHTML = '';
  last7.forEach((day, idx) => {
    const height = (day.calorias / maxCal) * 100;
    const isToday = day.date === getTodayKey();
    barsHTML += `
      <div class="chart-bar-wrap">
        <div class="chart-bar${isToday ? ' today' : ''}" style="height:${height}%"></div>
        <div class="chart-day">${day.date.split('-')[2]}</div>
        <div class="chart-kcal">${day.calorias}</div>
      </div>
    `;
  });

  document.getElementById('chartBars').innerHTML = barsHTML;
  chart.style.display = 'block';

  // Historial de comidas
  const itemsHTML = historyData.slice(0, 20).map(entry => {
    const d = new Date(entry.timestamp);
    const time = d.toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit' });
    return `
      <div class="history-item">
        <img class="history-thumb" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect fill='%23333' width='100' height='100'/%3E%3Ctext x='50' y='50' text-anchor='middle' dy='.3em' fill='%23999' font-size='40'%3E🍽️%3C/text%3E%3C/svg%3E" alt="">
        <div>
          <div class="history-dish">${escapeHTML(entry.plato)}</div>
          <div class="history-meta">${time}</div>
        </div>
        <div class="history-kcal">${entry.calorias}<span>kcal</span></div>
      </div>
    `;
  }).join('');

  list.innerHTML = itemsHTML;
}

function getLast7DaysData() {
  const data = {};
  
  for (let i = 6; i >= 0; i--) {
    const d = new Date();
    d.setDate(d.getDate() - i);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    data[key] = { date: key, calorias: 0 };
  }

  historyData.forEach(entry => {
    const d = new Date(entry.timestamp);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    if (data[key]) {
      data[key].calorias += entry.calorias || 0;
    }
  });

  return Object.values(data);
}

window.clearHistory = async function() {
  if (!confirm('¿Estás seguro? Esto no se puede deshacer.')) return;
  
  historyData = [];
  lsSet('nutrilent_history', []);
  await clearFirestoreHistory();
  renderHistory();
  updateMetasUI();
};

